{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=ClubReportHub_Report;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Jwt": {
    "Issuer": "ClubReportHub",
    "Audience": "ClubReportHub.Client",
    "SigningKey": "dev-only-change-this-signing-key-with-at-least-32-characters",
    "ExpirationMinutes": 120
  },
  "RabbitMQ": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "ExchangeName": "clubreport.events"
  },
  "Services": {
    "ClubService": {
      "BaseUrl": "http://club-service:8080"
    }
  },
  "Attachments": {
    "StoragePath": "attachments",
    "MaxSizeBytes": 10485760,
    "AllowedContentTypes": [
      "image/png",
      "image/jpeg",
      "application/pdf",
      "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
    ],
    "AllowedExtensions": [
      ".png",
      ".jpg",
      ".jpeg",
      ".pdf",
      ".xlsx"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
