{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=ClubReportHub_Report;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Jwt": {
    "Issuer": "ClubReportHub",
    "Audience": "ClubReportHub.Client",
    "SigningKey": "dev-only-change-this-signing-key-with-at-least-32-characters",
    "ExpirationMinutes": 120
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "StreamName": "clubreporthub-events",
    "ConsumerGroup": "notification-service",
    "BatchSize": 5,
    "PollIntervalMs": 1000
  },
  "Services": {
    "ClubService": {
      "BaseUrl": "http://club-service:8080"
    },
    "KpiGrpcService": {
      "BaseUrl": "http://localhost:5110"
    }
  },
  "Attachments": {
    "StoragePath": "attachments",
    "MaxSizeBytes": 10485760,
    "AllowedContentTypes": [
      "image/png",
      "image/jpeg",
      "application/pdf",
      "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
    ],
    "AllowedExtensions": [
      ".png",
      ".jpg",
      ".jpeg",
      ".pdf",
      ".xlsx"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
