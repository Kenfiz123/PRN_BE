{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=ClubReportHub_Export;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Jwt": {
    "Issuer": "ClubReportHub",
    "Audience": "ClubReportHub.Client",
    "SigningKey": "dev-only-change-this-signing-key-with-at-least-32-characters",
    "ExpirationMinutes": 120
  },
  "RabbitMQ": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "ExchangeName": "clubreport.events"
  },
  "Exports": {
    "StoragePath": "exports",
    "RetentionHours": 24
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
