{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=ClubReportHub_Export;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Jwt": {
    "Issuer": "ClubReportHub",
    "Audience": "ClubReportHub.Client",
    "SigningKey": "dev-only-change-this-signing-key-with-at-least-32-characters",
    "ExpirationMinutes": 120
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "StreamName": "clubreporthub-events",
    "ConsumerGroup": "notification-service",
    "BatchSize": 5,
    "PollIntervalMs": 1000
  },
  "Services": {
    "ClubService": {
      "BaseUrl": "http://localhost:5102"
    },
    "ReportService": {
      "BaseUrl": "http://localhost:5103"
    }
  },
  "Exports": {
    "StoragePath": "exports",
    "RetentionHours": 24
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
